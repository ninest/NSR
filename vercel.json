{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "redirects": [
    {
      "source": "/drill-commands",
      "destination": "/commands",
      "permanent": true
    },
    {
      "source": "/drill-commands/",
      "destination": "/commands/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/200.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
